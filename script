--  CHARACTER MODS
-- ═════════════════════════════════════════════════════════════
local Mods = { ijConn=nil, flyBV=nil, flyBG=nil, flyVel=ZV3, afkConn=nil, afkThread=nil }

local function setInfJump(on)
	if on then
		if Mods.ijConn then return end
		Mods.ijConn=svc.uis.JumpRequest:Connect(function()
			local hum=H.getHum(H.myChr())
			if hum then pcall(function() hum:ChangeState(Enum.HumanoidStateType.Jumping) end) end
		end); hook(Mods.ijConn)
	else
		if Mods.ijConn then pcall(function() Mods.ijConn:Disconnect() end); Mods.ijConn=nil end
	end
end

local function setFly(on)
	if on then
		local chr=H.myChr(); if not H.validChr(chr) then return end
		local root=H.getRoot(chr); if not root then return end
		pcall(function()
			if not Mods.flyBV then
				Mods.flyBV=Instance.new("BodyVelocity")
				Mods.flyBV.MaxForce=V3(huge,huge,huge)
				Mods.flyBV.Velocity=ZV3
			end
			if not Mods.flyBG then
				Mods.flyBG=Instance.new("BodyGyro")
				Mods.flyBG.MaxTorque=V3(huge,huge,huge)
			end
			Mods.flyBV.Parent=root; Mods.flyBG.Parent=root; Mods.flyVel=ZV3
		end)
	else
		pcall(function() if Mods.flyBV then Mods.flyBV.Parent=nil end end)
		pcall(function() if Mods.flyBG then Mods.flyBG.Parent=nil end end)
	end
end

local function tickFly()
	if not Cfg.misc.fly or not Mods.flyBV or not Mods.flyBG then return end
	local root=H.myRoot(); if not root then return end
	pcall(function()
		if Mods.flyBV.Parent~=root then Mods.flyBV.Parent=root end
		if Mods.flyBG.Parent~=root then Mods.flyBG.Parent=root end
		local spd=Cfg.misc.flySpd; local dir=ZV3
		local uis=svc.uis
		if uis:IsKeyDown(Enum.KeyCode.W) then dir=dir+F.camCF.LookVector end
		if uis:IsKeyDown(Enum.KeyCode.S) then dir=dir-F.camCF.LookVector end
		if uis:IsKeyDown(Enum.KeyCode.A) then dir=dir-F.camCF.RightVector end
		if uis:IsKeyDown(Enum.KeyCode.D) then dir=dir+F.camCF.RightVector end
		if uis:IsKeyDown(Enum.KeyCode.Space)       then dir=dir+V3(0,1,0) end
		if uis:IsKeyDown(Enum.KeyCode.LeftControl) then dir=dir-V3(0,1,0) end
		local tgt=dir.Magnitude>0 and dir.Unit*spd or ZV3
		Mods.flyVel=H.dampV3(Mods.flyVel,tgt,0.25,F.dt)
		Mods.flyBV.Velocity=Mods.flyVel; Mods.flyBG.CFrame=F.camCF
	end)
end

local function tickCharMods()
	local hum=H.getHum(H.myChr()); if not hum then return end
	pcall(function()
		if Cfg.misc.spdMod then hum.WalkSpeed=Cfg.misc.spdVal end
		if Cfg.misc.jmpMod then
			if hum.UseJumpPower then hum.JumpPower=Cfg.misc.jmpVal
			else hum.JumpHeight=Cfg.misc.jmpVal*0.25 end
		end
		if Cfg.misc.fovMod then svc.cam.FieldOfView=Cfg.misc.fovVal end
		if Cfg.misc.thirdPerson then
			svc.lp.CameraMinZoomDistance=Cfg.misc.tpDist
			svc.lp.CameraMaxZoomDistance=Cfg.misc.tpDist
		end
		if Cfg.misc.noFallDmg then
			pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown,false) end)
		end
	end)
end

local function tickAutoRespawn()
	if not Cfg.misc.autoRespawn then return end
	local hum=H.getHum(H.myChr())
	if hum and (H.prop(hum,"Health") or 100)<=0 then
		task.delay(.5,function() pcall(function() svc.lp.Character=nil end) end)
	end
end

local function tickNoclip()
	if not Cfg.misc.noclip then return end
	local chr=H.myChr(); if not H.validChr(chr) then return end
	pcall(function()
		for _,p in ipairs(chr:GetDescendants()) do
			if p:IsA("BasePart") then p.CanCollide=false end
		end
	end)
end

local function setAntiAfk(on)
	if on then
		if Mods.afkConn then return end
		Mods.afkConn=svc.lp.Idled:Connect(function()
			pcall(function()
				if svc.vu then
					svc.vu:Button2Down(ZV2,svc.cam.CFrame); task.wait(.1); svc.vu:Button2Up(ZV2,svc.cam.CFrame)
				elseif svc.vim then
					svc.vim:SendKeyEvent(true,Enum.KeyCode.Space,false,game); task.wait(.05); svc.vim:SendKeyEvent(false,Enum.KeyCode.Space,false,game)
				end
			end)
		end); hook(Mods.afkConn)
		Mods.afkThread=task.spawn(function()
			while Cfg.misc.antiAfk do
				task.wait(55)
				if not Cfg.misc.antiAfk then break end
				pcall(function()
					if svc.vu then svc.vu:Button1Down(ZV2,svc.cam.CFrame); task.wait(.05); svc.vu:Button1Up(ZV2,svc.cam.CFrame) end
				end)
			end
		end)
	else
		if Mods.afkConn then pcall(function() Mods.afkConn:Disconnect() end); Mods.afkConn=nil end
		Cfg.misc.antiAfk=false
	end
end

do
	if Cfg.misc.infJump then setInfJump(true) end
	if Cfg.misc.fly     then setFly(true)     end
	if Cfg.misc.antiAfk then setAntiAfk(true) end
	if Cfg.misc.ghost   then setGhost(true)   end
end

