--  TWEEN HELPER
-- ═════════════════════════════════════════════════════════════
local TwCache = {}
local function Tw(inst,pr,dur,sty)
	if not inst then return nil end
	dur=dur or .18; sty=sty or Enum.EasingStyle.Quint
	local old=TwCache[inst]; if old then pcall(old.Cancel,old) end
	local ok,t = pcall(function()
		return svc.ts:Create(inst,TweenInfo.new(dur,sty,Enum.EasingDirection.Out),pr)
	end)
	if not ok or not t then return nil end
	TwCache[inst]=t; t:Play()
	t.Completed:Once(function() if TwCache[inst]==t then TwCache[inst]=nil end end)
	return t
end

