function Viz.tickPath(basePos)
	if not Cfg.orbit.showPath or not Cfg.orbit.on then
		for i=1,#D.pathLines do dVis(D.pathLines[i],false) end; return
	end
	local segs = clamp(Cfg.orbit.pathSegs,12,64)
	ensureLines(D.pathLines,segs)
	local step = 360/segs
	local prevSp,prevOn
	for i=0,segs do
		local wPos = H.safeV3(basePos+computeOffset(i*step,Cfg.orbit.pattern))
		local sp,on = H.w2v(wPos)
		if i>0 then
			local ln = D.pathLines[i]
			if ln and prevOn and on and prevSp and sp then
				dSet(ln,"From",V2(prevSp.X,prevSp.Y)); dSet(ln,"To",V2(sp.X,sp.Y))
				dSet(ln,"Color",H.hsv(i/segs*0.8,0.8,1)); dSet(ln,"Transparency",0.35); dVis(ln,true)
			elseif ln then dVis(ln,false) end
		end
		prevSp=sp; prevOn=on
	end
	for i=segs+1,#D.pathLines do dVis(D.pathLines[i],false) end
end

function Viz.tickTrail(pos)
	if not Cfg.orbit.trail then
		for i=1,#D.trail do dVis(D.trail[i],false) end; return
	end
	local len = clamp(Cfg.orbit.trailLen,2,30)
	ensureCircs(D.trail,len)
	for i=len,2,-1 do
		local prev,cur2 = D.trail[i-1],D.trail[i]
		if Draw.alive[prev] and Draw.alive[cur2] then
			dSet(cur2,"Position",prev.Position); dSet(cur2,"Color",prev.Color)
		end
	end
	local sp,on = H.w2v(H.safeV3(pos))
	if on and sp and Draw.alive[D.trail[1]] then
		dSet(D.trail[1],"Position",V2(sp.X,sp.Y))
		dSet(D.trail[1],"Color",Thm.AccB)
		dSet(D.trail[1],"Transparency",0.9)
		dSet(D.trail[1],"Radius",3); dVis(D.trail[1],true)
	end
	for i=2,len do
		local c = D.trail[i]
		if Draw.alive[c] then
			local fade = Cfg.orbit.trailFade and (1-i/len)*0.82 or 0.6
			dSet(c,"Transparency",mx(fade,0.05))
			dSet(c,"Radius",mx(1,3*(1-i/len)))
			dSet(c,"Color",H.hsv(0.78-i/len*0.28,0.85,1))
			dVis(c,true)
		end
	end
	for i=len+1,#D.trail do dVis(D.trail[i],false) end
end

