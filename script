-- ═════════════════════════════════════════════════════════════
--  PATTERNS
-- ═════════════════════════════════════════════════════════════
local Patterns = {}
function Patterns.Circle(a,c)      local r=rad(a); return V3(cos(r)*c.distance,c.height,sin(r)*c.distance) end
function Patterns.Ellipse(a,c)     local r=rad(a); local rt=clamp(c.ellipseRatio,0.1,1); return V3(cos(r)*c.distance,c.height,sin(r)*c.distance*rt) end
function Patterns.Figure8(a,c)     local r=rad(a); local s2=sin(r); local den=mx(1+s2*s2,0.01); return V3(cos(r)/den*c.distance, c.height, (s2*cos(r)/den)*c.distance) end
function Patterns.Helix(a,c)       local r=rad(a); return V3(cos(r)*c.distance, c.height+sin(r*c.helixFreq)*c.helixAmp, sin(r)*c.distance) end
function Patterns.Sine(a,c)        local r=rad(a); local wave=sin(r*c.sineFreq)*c.sineAmp; return V3(cos(r)*c.distance+wave*sin(r), c.height, sin(r)*c.distance+wave*cos(r)) end
function Patterns.Flower(a,c)      local r=rad(a); local rr=c.distance*abs(cos(c.flowerPetals*r)); return V3(cos(r)*rr,c.height,sin(r)*rr) end
function Patterns.Lissajous(a,c)   local r=rad(a); local ph=rad(c.lissajousPhase); return V3(c.distance*sin(c.lissajousA*r+ph),c.height,c.distance*sin(c.lissajousB*r)) end
function Patterns.Spiral(a,c)      local r=rad(a); local pct=(a%360)/360; local sr=c.distance*(0.2+0.8*pct); return V3(cos(r)*sr,c.height+pct*c.helixAmp,sin(r)*sr) end
function Patterns.Square(a,c)      local r=rad(a); local nx,nz=cos(r),sin(r); local sc=c.distance/mx(abs(nx),abs(nz),0.01); return V3(nx*sc,c.height,nz*sc) end
function Patterns.Rose(a,c)        local r=rad(a); local rr=c.distance*abs(cos(c.roseK*r)); return V3(cos(r)*rr,c.height,sin(r)*rr) end
function Patterns.Epicycloid(a,c)
	local r=rad(a); local R2=c.distance; local r2=R2*c.epicR
	local x=(R2+r2)*cos(r)-r2*cos((R2+r2)*r/mx(r2,0.01))
	local z=(R2+r2)*sin(r)-r2*sin((R2+r2)*r/mx(r2,0.01))
	return V3(x*.5,c.height,z*.5)
end
function Patterns.Random(a,c)
	local r=rad(a)
	local nx=sin(r*1.7+0.3)*cos(r*0.9+1.1)*c.distance
	local nz=cos(r*1.3+0.7)*sin(r*2.1+0.5)*c.distance
	return V3(nx,c.height+sin(r*2.3)*c.helixAmp,nz)
end
local function computeOffset(angle,pat)
	local fn = Patterns[pat] or Patterns.Circle
	return fn(angle,Cfg.orbit)
end

