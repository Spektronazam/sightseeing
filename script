local function loadCfgFrom(file)
	local raw = IO.read(file); if not raw then return end
	local d = IO.jsonDecode(raw); if type(d)~="table" then return end
	for cat,tbl in pairs(d) do
		if type(tbl)=="table" and Cfg[cat] then
			for k,v in pairs(tbl) do
				if Cfg[cat][k]~=nil and type(v)==type(Cfg[cat][k]) then
					Cfg[cat][k]=v
				end
			end
		end
	end
end

