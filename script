--  LINE OF SIGHT CHECK
-- ═════════════════════════════════════════════════════════════
local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude
rayParams.IgnoreWater = true

local function hasLineOfSight(toPos, ignoreList)
	local fromRoot = H.myRoot()
	if not fromRoot then return true end
	local origin = fromRoot.Position + V3(0,1.6,0)
	local dir = (toPos - origin)
	if dir.Magnitude < 1 then return true end
	rayParams.FilterDescendantsInstances = ignoreList or {H.myChr()}
	local hit = svc.ws:Raycast(origin, dir, rayParams)
	return hit == nil
end

-- ═════════════════════════════════════════════════════════════
--  SMART TARGETING
-- ═════════════════════════════════════════════════════════════
local function scoreTarget(p)
	local root = H.getRoot(H.prop(p,"Character")); if not root then return huge end
	local myRoot = H.myRoot(); if not myRoot then return huge end
	local ok,dist = pcall(function() return (root.Position-myRoot.Position).Magnitude end)
	if not ok then return huge end
	if Cfg.orbit.losCheck and not hasLineOfSight(root.Position + V3(0,1.5,0), {H.myChr(), H.prop(p,"Character")}) then
		dist = dist + 250
	end
	local hum = H.getHum(H.prop(p,"Character"))
	local hp  = hum and H.prop(hum,"Health") or 1
	local maxHp = hum and H.prop(hum,"MaxHealth") or 100
	local hpRatio = hp / mx(maxHp,1)
	return dist * 0.55 + hpRatio * 220
end

local function findBestTarget()
	local best,bs = nil,huge
	for _,p in ipairs(svc.plrs:GetPlayers()) do
		if p==svc.lp or not H.isAlive(p) then continue end
		if not wlCheck(p.Name) then continue end
		local sc = scoreTarget(p)
		if sc < bs then bs=sc; best=p end
	end
	return best
end

local function findNearest()
	if Cfg.orbit.smartTarget then return findBestTarget() end
	local best,bd = nil,huge
	local myRoot  = H.myRoot(); if not myRoot then return nil end
	local myPos = myRoot.Position
	for _,p in ipairs(svc.plrs:GetPlayers()) do
		if p==svc.lp or not H.isAlive(p) then continue end
		if not wlCheck(p.Name) then continue end
		local root = H.getRoot(H.prop(p,"Character")); if not root then continue end
		local d = (root.Position-myPos).Magnitude
		if Cfg.orbit.losCheck and not hasLineOfSight(root.Position + V3(0,1.5,0), {H.myChr(), H.prop(p,"Character")}) then
			d = d + 250
		end
		if d < bd then bd=d; best=p end
	end
	return best
end

