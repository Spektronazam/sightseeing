local function tickAntiVoid()
	if not Cfg.orbit.antiVoid then return end
	local root=H.myRoot(); if not root then return end
	pcall(function()
		if root.Position.Y < Cfg.orbit.voidFloor then
			root.CFrame=CF(V3(root.Position.X,Cfg.orbit.voidFloor+50,root.Position.Z))
			root.AssemblyLinearVelocity=ZV3
			pushNf("Anti-void triggered!",2,"warning")
		end
	end)
end
local function orbitNoclip()
	local chr=H.myChr(); if not H.validChr(chr) then return end
	pcall(function()
		for _,p in ipairs(chr:GetDescendants()) do
			if p:IsA("BasePart") then p.CanCollide=false end
		end
	end)
end

-- ═════════════════════════════════════════════════════════════
--  MAIN ORBIT TICK
-- ═════════════════════════════════════════════════════════════
local function applyRootCF(goalPos,lookAt)
	local myRoot = H.myRoot(); if not myRoot then return end
	goalPos = H.safeV3(goalPos)

	local s = clamp(Cfg.orbit.smoothness*0.04,0.02,1)
	Orb.currentPos = Orb.currentPos and H.dampV3(Orb.currentPos,goalPos,s,F.dt) or goalPos
	Orb.currentPos = H.safeV3(Orb.currentPos)

	if Orb.prevPos then
		Orb.speedMag = (Orb.currentPos-Orb.prevPos).Magnitude/mx(F.dt,0.001)
	end
	Orb.prevPos = Orb.currentPos

	local fCF = lookAt and Cfg.orbit.lookAt and CF(Orb.currentPos,H.safeV3(lookAt)) or CF(Orb.currentPos)
	if abs(Orb.bankAngle) > 0.1 then fCF = fCF * CFrame.Angles(0,0,rad(Orb.bankAngle)) end

	pcall(function()
		if myRoot.Anchored then myRoot.Anchored=false end
		myRoot.CFrame=fCF
		myRoot.AssemblyLinearVelocity=ZV3
		myRoot.AssemblyAngularVelocity=ZV3
	end)
	recTick(Orb.currentPos)
end

local function tickOrbitInner(dt)
	if not Cfg.orbit.on then
		Cam.tgtAlive=false; Cam.tgtPos=nil
		if Orb.state~="idle" then transitionToIdle() end
		return
	end

	if Rec.replaying then
		local rpos = recGetReplayPos()
		if rpos then applyRootCF(rpos,nil) end
		Orb.state="replaying"
		return
	end

	if Cfg.orbit.autoNearest then
		if (tk()-Orb.lastAutoSwitchT) >= mx(Cfg.orbit.autoSwitchCooldown,0.2) then
			local nearest = findNearest()
			if nearest and nearest.Name~=Cfg.orbit.targetName then
				Orb.lastAutoSwitchT = tk()
				Cfg.orbit.targetName=nearest.Name
				Orb.state="idle"
				pushNf("Auto → "..nearest.Name,2,"orbit")
				if UI.tgtDD and UI.tgtDD.Set then UI.tgtDD.Set(nearest.Name) end
			end
		end
	end

	local tgtPlr = resolveTarget()
	if not tgtPlr then
		if tk()-Warn.noTargetT > 2.2 then
			Warn.noTargetT = tk()
			pushNf("No target selected (pick one in UI)", 2.2, "warning")
		end
		if Orb.state~="idle" then transitionToIdle() end
		return
	end
	if tgtPlr~=Orb.tgtPlr then clearTgtConns(); setupTargetHooks(tgtPlr); Orb.state="idle" end

	local myRoot = H.myRoot(); if not myRoot then return end
	if Cfg.orbit.autoNoclip then orbitNoclip() end

	if Cfg.orbit.speedRamp then
		if Orb.frozen then Orb.curSpeed=H.damp(Orb.curSpeed,0,Cfg.orbit.rampDecel*0.2,dt)
		else           Orb.curSpeed=H.damp(Orb.curSpeed,Cfg.orbit.speed,Cfg.orbit.rampAccel*0.2,dt) end
	else
		Orb.curSpeed=H.damp(Orb.curSpeed,Orb.frozen and 0 or Cfg.orbit.speed,0.5,dt)
	end

	Orb.prevAngle=Orb.angle
	Orb.angle=(Orb.angle+Orb.curSpeed*dt*Orb.direction)%3600

	if Cfg.orbit.banking then
		local delta=Orb.angle-Orb.prevAngle
		local gb=clamp(delta*Cfg.orbit.bankAngle*0.1,-Cfg.orbit.bankAngle,Cfg.orbit.bankAngle)
		Orb.bankAngle=H.damp(Orb.bankAngle,gb,Cfg.orbit.bankSmooth*0.04,dt)
	else
		Orb.bankAngle=H.damp(Orb.bankAngle,0,0.2,dt)
	end

	local tgtChr   = H.prop(tgtPlr,"Character")
	local tgtRoot  = H.validChr(tgtChr) and H.getRoot(tgtChr) or nil
	local tgtAlive = H.isAlive(tgtPlr)
	local isFollow = Cfg.orbit.mode=="Follow"

	Cam.tgtAlive = (tgtRoot~=nil and tgtAlive)
	Cam.tgtPos   = (tgtRoot and getTargetWorldPos(tgtRoot)) or Orb.lastKnownPos

	if Orb.state=="idle" then
		if tgtRoot and tgtAlive then
			Orb.state = isFollow and "following" or "orbiting"
			Orb.lastKnownPos = H.safeV3(tgtRoot.Position)
			Orb.currentPos   = H.safeV3(myRoot.Position)
			pushNf((isFollow and "Following " or "Orbiting ")..tgtPlr.Name,2,"orbit")
		else
			Orb.lastKnownPos=Orb.lastKnownPos or H.safeV3(myRoot.Position)
			Orb.currentPos=H.safeV3(myRoot.Position)
			Orb.state="ascending"
		end
	end

	if Orb.state=="orbiting" then
		if not tgtRoot or not tgtAlive then
			if tgtRoot then Orb.lastKnownPos=H.safeV3(tgtRoot.Position) end
			Orb.state="ascending"; pushNf(tgtPlr.Name.." died",3,"warning")
		else
			local wp=getTargetWorldPos(tgtRoot); Orb.lastKnownPos=wp
			applyRootCF(wp+computeOffset(Orb.angle,Cfg.orbit.pattern),wp)
			Viz.tickPath(wp); Viz.tickTrail(Orb.currentPos)
			Viz.tickTargetESP(tgtPlr,tgtRoot); Viz.tickHudCompass(wp)
		end

	elseif Orb.state=="following" then
		if not tgtRoot or not tgtAlive then
			if tgtRoot then Orb.lastKnownPos=H.safeV3(tgtRoot.Position) end
			Orb.state="ascending"; pushNf(tgtPlr.Name.." died",3,"warning")
		else
			local wp=getTargetWorldPos(tgtRoot); Orb.lastKnownPos=wp
			local vel=smoothedVel(tgtRoot); local fv=V3(vel.X,0,vel.Z)
			local behind=fv.Magnitude>1 and (-fv.Unit) or H.safeV3(myRoot.Position-wp).Unit
			behind=V3(behind.X,0,behind.Z)
			if behind.Magnitude<0.1 then behind=V3(0,0,1) end
			behind=behind.Unit

			local gp=wp+behind*Cfg.orbit.followDist+V3(0,Cfg.orbit.followOffY,0)
			local fs=clamp(Cfg.orbit.followSmooth*0.04,0.02,1)
			Orb.currentPos=Orb.currentPos and H.dampV3(Orb.currentPos,H.safeV3(gp),fs,dt) or H.safeV3(gp)
			local fCF=Cfg.orbit.lookAt and CF(Orb.currentPos,wp) or CF(Orb.currentPos)
			if abs(Orb.bankAngle)>0.1 then fCF=fCF*CFrame.Angles(0,0,rad(Orb.bankAngle)) end
			pcall(function() myRoot.CFrame=fCF; myRoot.AssemblyLinearVelocity=ZV3; myRoot.AssemblyAngularVelocity=ZV3 end)
			recTick(Orb.currentPos)

			Viz.tickTrail(Orb.currentPos); Viz.tickTargetESP(tgtPlr,tgtRoot); Viz.tickHudCompass(wp)
			for i=1,#D.pathLines do dVis(D.pathLines[i],false) end
		end

	elseif Orb.state=="ascending" then
		local bp=Orb.lastKnownPos or V3(0,100,0)
		local sc=V3(bp.X,bp.Y+Cfg.orbit.skyHeight,bp.Z)
		local r2=rad(Orb.angle)
		applyRootCF(sc+V3(cos(r2)*Cfg.orbit.distance,0,sin(r2)*Cfg.orbit.distance),sc)
		if Orb.currentPos and (H.safeV3(Orb.currentPos)-H.safeV3(sc)).Magnitude<5 then
			Orb.state="hovering"; pushNf("Hovering — waiting...",3,"info")
		end
		if tgtRoot and tgtAlive then
			Orb.lastKnownPos=H.safeV3(tgtRoot.Position)
			Orb.state="descending"; pushNf(tgtPlr.Name.." respawned",3,"success")
		end
		Viz.tickTrail(Orb.currentPos); Viz.tickTargetESP(tgtPlr,tgtRoot); Viz.tickHudCompass(Orb.lastKnownPos)

	elseif Orb.state=="hovering" then
		local bp=Orb.lastKnownPos or V3(0,100,0)
		local hc=V3(bp.X,bp.Y+Cfg.orbit.skyHeight,bp.Z)
		local r2=rad(Orb.angle)
		applyRootCF(hc+V3(cos(r2)*Cfg.orbit.distance,0,sin(r2)*Cfg.orbit.distance),hc)
		if tgtRoot and tgtAlive then
			Orb.lastKnownPos=H.safeV3(tgtRoot.Position)
			Orb.state="descending"; pushNf(tgtPlr.Name.." respawned",3,"success")
		end
		Viz.tickTrail(Orb.currentPos); Viz.tickTargetESP(tgtPlr,tgtRoot); Viz.tickHudCompass(Orb.lastKnownPos)

	elseif Orb.state=="descending" then
		if not tgtRoot or not tgtAlive then Orb.state="ascending"; return end
		local wp=getTargetWorldPos(tgtRoot); Orb.lastKnownPos=wp
		local gp=wp+computeOffset(Orb.angle,Cfg.orbit.pattern); applyRootCF(gp,wp)
		if Orb.currentPos and (H.safeV3(Orb.currentPos)-H.safeV3(gp)).Magnitude<5 then
			Orb.state=isFollow and "following" or "orbiting"
			pushNf("Resumed "..Cfg.orbit.mode,2,"success")
		end
		Viz.tickPath(wp); Viz.tickTrail(Orb.currentPos); Viz.tickTargetESP(tgtPlr,tgtRoot); Viz.tickHudCompass(wp)
	end

	tickAntiVoid()
	Viz.tickCrosshair()
	Viz.tickRadar()
	Viz.tickSpeedLines()
	Viz.tickCoordDisplay()

	if UI.statusLabel and UI.statusLabel.SetText then
		local stTxt=OrbNames[Orb.state] or Orb.state
		local extra=""
		if Orb.frozen then extra=extra.." ❄" end
		if Cfg.misc.ghost then extra=extra.." 👻" end
		if AP.on then extra=extra.." ⚡" end
		if Rec.recording then extra=extra.." ⏺" end
		if Rec.replaying then extra=extra.." ▶" end
		if Cam.phase~="idle" and Cam.phase~="track_target" and Cfg.orbit.camMode~="Free" then extra=extra.." 🎬" end
		UI.statusLabel.SetText(stTxt..extra)
	end
end
local function tickOrbit(dt) safe(tickOrbitInner,dt) end

