local WL = {list={}, enabled=false}
local WL_FILE = "DESPAIR_WHITELIST.txt"

local function wlSave()
	if not Cap.writefile then return end
	local lines={}
	for n in pairs(WL.list) do lines[#lines+1]=n end
	tsort(lines)
	IO.write(WL_FILE, tconcat(lines,"\n"))
end
local function wlLoad()
	local d = IO.read(WL_FILE); if not d then return end
	WL.list={}
	for n in d:gmatch("[^\n]+") do
		n=n:match("^%s*(.-)%s*$")
		if n and #n>0 then WL.list[slow(n)]=true end
	end
end
local function wlCheck(n) if not WL.enabled then return true end return n and WL.list[slow(n)] or false end

