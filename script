            Text="Auto key press", Default=Cfg.misc.autoPress,
            Callback=function(v) Cfg.misc.autoPress=v; AP.on=v end
        })
        tabAP:AddTextInput({
            Text="Key (e.g. Q, E, F)", Default=Cfg.misc.apKey,
            Callback=function(t) t=tostring(t or ""):match("^%s*(.-)%s*$"); if t=="" then t="Q" end; Cfg.misc.apKey=t; AP.key=t end
        })
        tabAP:AddTextInput({
            Text="Interval (sec)", Default=tostring(Cfg.misc.apInterval),
            Callback=function(t) local n=tonumber(t); if n then Cfg.misc.apInterval=clamp(n,0.02,5); AP.interval=Cfg.misc.apInterval end end
        })
        tabAP:AddTextInput({
            Text="Hold duration (sec)", Default=tostring(Cfg.misc.apDuration),
            Callback=function(t) local n=tonumber(t); if n then Cfg.misc.apDuration=clamp(n,0.01,2); AP.duration=Cfg.misc.apDuration end end
        })

        -- Config
        local secCfg  = win:AddSection("Config", "⚙")
        local tabCfg  = secCfg:AddTab("Config")
        tabCfg:AddToggle({
            Text    = "Use whitelist file",
            Default = Cfg.misc.whitelist,
            Callback = function(v)
                Cfg.misc.whitelist = v
                WL.enabled = v
                wlSave()
            end,
        })
        UI.wlCountLbl = tabCfg:AddLabel("Whitelist: DESPAIR_WHITELIST.txt (edit manually)")
        tabCfg:AddToggle({Text="Watermark", Default=Cfg.misc.wm, Callback=function(v) Cfg.misc.wm=v end})
        tabCfg:AddTextInput({
            Text="UI corner radius", Default=tostring(Cfg.ui.corner or 10),
            Callback=function(t) local n=tonumber(t); if n then win:SetCorner(n) end end
        })
        tabCfg:AddSeparator()
        local function bindKeyInput(label, cfgKey)
            tabCfg:AddTextInput({
                Text        = label,
                Default     = Cfg.orbit[cfgKey],
                Placeholder = "None or key (Q,E,Tab,...)",
                Callback    = function(t)
                    t = tostring(t or ""):match("^%s*(.-)%s*$")
                    if t == "" then t = "None" end
                    Cfg.orbit[cfgKey] = t
                end
            })
        end
        bindKeyInput("Toggle orbit key",  "toggleKey")
        bindKeyInput("Reverse direction key", "reverseKey")
        bindKeyInput("Freeze orbit key",  "freezeKey")
        bindKeyInput("Next target key",   "cycleNextKey")
        bindKeyInput("Prev target key",   "cyclePrevKey")
        bindKeyInput("Ghost toggle key",  "ghostKey")

        win:SetCorner(Cfg.ui.corner or 10)
    end
end

-- ═════════════════════════════════════════════════════════════
--  CLEANUP
-- ═════════════════════════════════════════════════════════════
_G.DESPAIRv8Cleanup=function()
	pcall(function() svc.rs:UnbindFromRenderStep(CAM_KEY) end)
	disengageCam()
	unhookAll()
	clearTgtConns()
	Orb.state="idle"; Orb.tgtPlr=nil; Orb.currentPos=nil
	AP.on=false; Cfg.misc.antiAfk=false

	pcall(function() svc.cam.CameraType=Enum.CameraType.Custom; svc.cam.FieldOfView=70 end)
	pcall(function() svc.lp.CameraMinZoomDistance=.5; svc.lp.CameraMaxZoomDistance=400 end)
	pcall(function() local hum=H.getHum(H.myChr()); if hum then svc.cam.CameraSubject=hum end end)

	for p,orig in pairs(Mat.originals) do if p and p.Parent then pcall(function() p.Material=orig end) end end
	for p,orig in pairs(Mat.faded)     do if p and p.Parent then pcall(function() p.Transparency=orig end) end end
	Mat.originals={}; Mat.active={}; Mat.faded={}; VB.data={}

	hideAllViz()

	for d in pairs(Draw.alive) do dNuke(d) end
	Draw.alive=setmetatable({},{__mode="k"})
	Draw.count=0

	if Cfg.misc.fly then setFly(false) end
	H.kill(Mods.flyBV); Mods.flyBV=nil
	H.kill(Mods.flyBG); Mods.flyBG=nil

	pcall(function()
		local chr=H.myChr()
		if chr then
			for _,p in ipairs(chr:GetDescendants()) do
				if p:IsA("BasePart") then p.CanCollide=true end
			end
		end
	end)

	if svc.cas then pcall(function() svc.cas:UnbindAction("DESPAIR_BlockClick") end) end

	pcall(saveCfg)
	if _G.DESPAIR_GUI_Ref and _G.DESPAIR_GUI_Ref.Parent then pcall(function() _G.DESPAIR_GUI_Ref:Destroy() end) end
	_G.DESPAIR_GUI_Ref=nil
	_G.DESPAIRv8Cleanup=nil
end
