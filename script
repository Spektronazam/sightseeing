local H = {}

function H.prop(i,p)  local ok,v=pcall(function() return i[p] end) return ok and v or nil end
function H.set(i,p,v) pcall(function() i[p]=v end) end
function H.kill(i)    if i then pcall(function() i:Destroy() end) end end
function H.mk(cn,pr)
	local ok,i = pcall(Instance.new,cn)
	if not ok or not i then return nil end
	if pr then for k,v in pairs(pr) do pcall(function() i[k]=v end) end end
	return i
end

function H.lerp(a,b,t)  return a+(b-a)*clamp(t,0,1) end
function H.lerpV3(a,b,t)
	t=clamp(t,0,1)
	return V3(H.lerp(a.X,b.X,t),H.lerp(a.Y,b.Y,t),H.lerp(a.Z,b.Z,t))
end
function H.damp(c,g,sp,dt) return H.lerp(c,g,1-exp(-sp*dt*12)) end
function H.dampV3(c,g,sp,dt) return H.lerpV3(c,g,1-exp(-sp*dt*12)) end
function H.safeV3(v)
	if not v or typeof(v)~="Vector3" then return ZV3 end
	if v.X~=v.X or v.Y~=v.Y or v.Z~=v.Z then return ZV3 end
	return V3(clamp(v.X,-1e6,1e6),clamp(v.Y,-1e6,1e6),clamp(v.Z,-1e6,1e6))
end
function H.hsv(h,s,v) return Color3.fromHSV(clamp(h,0,1),clamp(s,0,1),clamp(v,0,1)) end
function H.w2v(pos)
	local ok,sp,on = pcall(function() return svc.cam:WorldToViewportPoint(H.safeV3(pos)) end)
	return ok and sp or nil, ok and on or false
end
function H.validChr(c)
	if not c then return false end
	local ok,pa = pcall(function() return c.Parent end)
	return ok and pa ~= nil
end
function H.getHum(c)
	if not H.validChr(c) then return nil end
	local ok,h = pcall(function() return c:FindFirstChildOfClass("Humanoid") end)
	return ok and h or nil
end
function H.getRoot(c)
	if not H.validChr(c) then return nil end
	local ok,r = pcall(function()
		return c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso")
	end)
	return ok and r or nil
end
function H.isAlive(p)
	if not p then return false end
	local okPar = pcall(function() return p.Parent end)
	if not okPar then return false end
	local chr = H.prop(p,"Character")
	if not H.validChr(chr) then return false end
	local hum = H.getHum(chr)
	local hp  = hum and H.prop(hum,"Health")
	return hp and hp > 0
end
function H.myChr()  return H.prop(svc.lp,"Character") end
function H.myRoot() return H.getRoot(H.myChr()) end

