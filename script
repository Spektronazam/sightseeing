end))

hook(svc.rs.Heartbeat:Connect(function(dt)
	tickOrbit(dt)
	safe(tickFly)
	safe(tickAutoPress)

	Tick.slow+=dt
	if Tick.slow>=0.2 then
		Tick.slow=0
		safe(tickCharMods)
		safe(tickAutoRespawn)
	end

	Tick.mat+=dt
	if Tick.mat>=0.05 then Tick.mat=0; safe(tickSmartMat) end

	Tick.save+=dt
