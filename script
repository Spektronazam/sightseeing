-- ═════════════════════════════════════════════════════════════
--  UI LIBRARY (fixed tabs + overlay + player dropdown + click sink)
-- ═════════════════════════════════════════════════════════════
local Library = {}

function Library:CreateWindow(title)
    local parent = svc.cg
    if not parent then
        local ok,pg=pcall(function() return svc.lp:WaitForChild("PlayerGui",5) end)
        parent = ok and pg or nil
    end
    if not parent then warn("[DESPAIR v8] No GUI parent."); return nil end

    local uid = "DESPAIRv83_"..tostring(rng(1e5,9e5))
    local SG  = H.mk("ScreenGui",{
        Name=uid, Parent=parent, ResetOnSpawn=false,
        IgnoreGuiInset=true, ZIndexBehavior=Enum.ZIndexBehavior.Sibling,
    })
    if not SG then return nil end
    _G.DESPAIR_GUI_Ref = SG

    local Win = {
        SG=SG,
        Root=nil,
        Shadow=nil,
        Sections={},
        ActiveSection=nil,
        Corners={},
        uiVisible=true,
        Overlay=nil,
        OpenMenu=nil,
        CloseMenu=nil,
        MenuActive=nil,
    }

    function Win:_corner(inst)
        local cr = H.mk("UICorner",{Parent=inst, CornerRadius=UDim.new(0, Cfg.ui.corner or 0)})
        if cr then self.Corners[#self.Corners+1]=cr end
        return cr
    end

    function Win:SetCorner(px)
        px = clamp(floor((tonumber(px) or 0)+0.5), 0, 18)
        Cfg.ui.corner = px
        for _,cr in ipairs(self.Corners) do
            if cr and cr.Parent then
                Tw(cr, {CornerRadius=UDim.new(0,px)}, 0.18, Enum.EasingStyle.Sine)
            end
        end
        task.defer(saveCfg)
    end

    local Shadow = H.mk("ImageLabel",{
        Parent=SG, BackgroundTransparency=1,
        Position=UDim2.new(0,42,0,42), Size=UDim2.new(0,Thm.W+22,0,Thm.H+22),
        Image="rbxassetid://5554236805", ImageColor3=Color3.new(0,0,0),
        ImageTransparency=0.55, ScaleType=Enum.ScaleType.Slice,
        SliceCenter=Rect.new(23,23,277,277), ZIndex=9,
    })

    local Root = H.mk("Frame",{
        Parent=SG, BackgroundColor3=Thm.Base,
        Position=UDim2.new(0,54,0,54), Size=UDim2.new(0,Thm.W,0,Thm.H),
        BorderSizePixel=0, ZIndex=10,
    })
    Win.Shadow=Shadow; Win.Root=Root
    Win:_corner(Root)
    H.mk("UIStroke",{Parent=Root,Color=Thm.Stroke2,Thickness=1,Transparency=0.55})

    local Overlay = H.mk("Frame",{
        Parent=SG, BackgroundTransparency=1,
        Position=UDim2.new(0,0,0,0), Size=UDim2.new(1,0,1,0),
        Visible=false, Active=true, ZIndex=25000,
    })
    Win.Overlay = Overlay

    function Win:CloseMenu()
        if Win.MenuActive then
            pcall(function() Win.MenuActive:Destroy() end)
            Win.MenuActive=nil
        end
        if Overlay then Overlay.Visible=false end
    end
    hook(Overlay.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            Win:CloseMenu()
        end
    end))

    function Win:OpenMenuAt(absPos, size, buildFn)
        self:CloseMenu()
        Overlay.Visible=true
        local menu = H.mk("Frame",{
            Parent=Overlay, BackgroundColor3=Thm.Panel2,
            Position=UDim2.fromOffset(absPos.X, absPos.Y),
            Size=UDim2.fromOffset(size.X, size.Y),
            BorderSizePixel=0, ZIndex=25001,
        })
        self:_corner(menu)
        H.mk("UIStroke",{Parent=menu,Color=Thm.Stroke,Thickness=1,Transparency=0.55})

        Win.MenuActive=menu
        if buildFn then pcall(buildFn, menu) end
        return menu
    end

    -- Global click sink so UI doesn't click-through to game buttons
    if svc.cas then
        pcall(function()
            svc.cas:BindAction("DESPAIR_BlockClick", function(_, state, input)
                if state ~= Enum.UserInputState.Begin then
                    return Enum.ContextActionResult.Pass
                end
                if not Win.Root or not Win.Root.Visible then
                    return Enum.ContextActionResult.Pass
                end
                local pos = input.Position
                if not pos then
                    return Enum.ContextActionResult.Pass
                end
                local objs = svc.uis:GetGuiObjectsAtPosition(pos.X,pos.Y)
                for _,g in ipairs(objs) do
                    if g:IsDescendantOf(Win.Root) or (Win.Overlay and g:IsDescendantOf(Win.Overlay)) then
                        return Enum.ContextActionResult.Sink
                    end
                end
                return Enum.ContextActionResult.Pass
            end, false, Enum.UserInputType.MouseButton1)
        end)
    end

    -- Header
    local hdr = H.mk("Frame",{Parent=Root,BackgroundColor3=Thm.Base,Size=UDim2.new(1,0,0,44),BorderSizePixel=0,ZIndex=11})
    Win:_corner(hdr)
    H.mk("UIStroke",{Parent=hdr,Color=Thm.Stroke,Thickness=1,Transparency=0.7})

    H.mk("TextLabel",{Parent=hdr,BackgroundTransparency=1,Position=UDim2.new(0,14,0,0),Size=UDim2.new(1,-120,1,0),
        Text=title,TextColor3=Thm.AccB,Font=Thm.BFnt,TextSize=18,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=12})
    H.mk("TextLabel",{Parent=hdr,BackgroundTransparency=1,Position=UDim2.new(1,-90,0,0),Size=UDim2.new(0,80,1,0),
        Text="v8.3",TextColor3=Thm.Sub,Font=Thm.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=12})

    local aBar = H.mk("Frame",{Parent=hdr,BackgroundColor3=Thm.Acc,Size=UDim2.new(1,-18,0,2),Position=UDim2.new(0,9,1,-3),BorderSizePixel=0,ZIndex=12})
    Win:_corner(aBar)

    -- Drag with inertia
    do
        local dragBtn = H.mk("TextButton",{Parent=hdr,BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text="",ZIndex=20})
        local Drag = {active=false,start=ZV2,startPos=nil,vel=ZV2,last=ZV2}
        hook(dragBtn.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                local p=V2(i.Position.X,i.Position.Y)
                Drag.active=true; Drag.start=p; Drag.startPos=Root.Position; Drag.vel=ZV2; Drag.last=p
            end
        end))
        hook(svc.uis.InputChanged:Connect(function(i)
            if Drag.active and i.UserInputType==Enum.UserInputType.MouseMovement then
                local cur=V2(i.Position.X,i.Position.Y)
                Drag.vel=Drag.vel*0.7+(cur-Drag.last)*0.3
                Drag.last=cur
                local d=cur-Drag.start
                local nx=clamp(Drag.startPos.X.Offset+d.X,0,F.vpX-Thm.W)
                local ny=clamp(Drag.startPos.Y.Offset+d.Y,0,F.vpY-Thm.H)
                Root.Position=UDim2.new(0,nx,0,ny)
                if Shadow then Shadow.Position=UDim2.new(0,nx-10,0,ny-10) end
            end
        end))
        hook(dragBtn.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                Drag.active=false
                task.spawn(function()
                    while Drag.vel.Magnitude>0.5 do
                        local p3=Root.Position
                        local nx=clamp(p3.X.Offset+Drag.vel.X*0.08,0,F.vpX-Thm.W)
                        local ny=clamp(p3.Y.Offset+Drag.vel.Y*0.08,0,F.vpY-Thm.H)
                        Root.Position=UDim2.new(0,nx,0,ny)
                        if Shadow then Shadow.Position=UDim2.new(0,nx-10,0,ny-10) end
                        Drag.vel=Drag.vel*0.88
                        task.wait()
                    end
                end)
            end
        end))
    end

    -- Body
    local body = H.mk("Frame",{Parent=Root,BackgroundTransparency=1,Position=UDim2.new(0,0,0,44),Size=UDim2.new(1,0,1,-44),BorderSizePixel=0,ZIndex=11})

    -- Sideboard
    local sideW = 140
    local side = H.mk("ScrollingFrame",{
        Parent=body, BackgroundColor3=Thm.Base, Size=UDim2.new(0,sideW,1,0),
        CanvasSize=UDim2.new(0,0,0,0), ScrollBarThickness=3, ScrollBarImageColor3=Thm.AccD,
        BorderSizePixel=0, ZIndex=12,
    })
    H.mk("UIStroke",{Parent=side,Color=Thm.Stroke,Thickness=1,Transparency=0.75})
    local sideList = H.mk("UIListLayout",{Parent=side,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6)})
    H.mk("UIPadding",{Parent=side,PaddingTop=UDim.new(0,10),PaddingLeft=UDim.new(0,10),PaddingRight=UDim.new(0,10),PaddingBottom=UDim.new(0,10)})

    hook(sideList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        side.CanvasSize = UDim2.new(0,0,0,sideList.AbsoluteContentSize.Y + 20)
    end))

    local content = H.mk("Frame",{Parent=body,BackgroundTransparency=1,Position=UDim2.new(0,sideW+10,0,0),Size=UDim2.new(1,-(sideW+10),1,0),BorderSizePixel=0,ZIndex=12})

    -- Insert toggle
    hook(svc.uis.InputBegan:Connect(function(inp,gpe)
        if gpe then return end
        if inp.KeyCode==Enum.KeyCode.Insert then
            Win.uiVisible=not Win.uiVisible
            if Win.uiVisible then
                Root.Visible=true; if Shadow then Shadow.Visible=true end
                H.set(Root,"BackgroundTransparency",1); Tw(Root,{BackgroundTransparency=0},.18,Enum.EasingStyle.Sine)
            else
                Tw(Root,{BackgroundTransparency=1},.14,Enum.EasingStyle.Sine)
                task.delay(.14,function()
                    if not Win.uiVisible then Root.Visible=false; if Shadow then Shadow.Visible=false end end
                end)
                Win:CloseMenu()
            end
            pushNf(Win.uiVisible and "UI shown" or "UI hidden",1.4,"info")
        end
    end))

    -- Sections
    local function selectSection(sec)
        if Win.ActiveSection==sec then return end
        Win.ActiveSection=sec
        for _,s in ipairs(Win.Sections) do
            local is = (s==sec)
            s.Page.Visible = is
            Tw(s.Btn,{BackgroundColor3=is and Thm.Panel2 or Thm.Panel},.12,Enum.EasingStyle.Sine)
            Tw(s.BtnTx,{TextColor3=is and Thm.AccB or Thm.Sub},.12,Enum.EasingStyle.Sine)
        end
        sec:SelectTab(sec.ActiveTab or sec.Tabs[1])
    end

    function Win:AddSection(name, icon)
        local sec = {Name=name, Icon=icon or "•", Tabs={}, ActiveTab=nil, TabWidth=0}

        local btn = H.mk("TextButton",{Parent=side,BackgroundColor3=Thm.Panel,Size=UDim2.new(1,0,0,36),Text="",AutoButtonColor=false,BorderSizePixel=0,ZIndex=13})
        Win:_corner(btn)
        H.mk("UIStroke",{Parent=btn,Color=Thm.Stroke,Thickness=1,Transparency=0.65})

        local tx = H.mk("TextLabel",{Parent=btn,BackgroundTransparency=1,Position=UDim2.new(0,10,0,0),Size=UDim2.new(1,-10,1,0),
            Text=(icon and (icon.."  "..name) or name),TextColor3=Thm.Sub,Font=Thm.BFnt,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=14})
        sec.Btn,sec.BtnTx = btn,tx

        local page = H.mk("Frame",{Parent=content,BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Visible=false,BorderSizePixel=0,ZIndex=12})
        sec.Page = page

        local top = H.mk("Frame",{Parent=page,BackgroundColor3=Thm.Base,Size=UDim2.new(1,0,0,38),BorderSizePixel=0,ZIndex=13})
        H.mk("UIStroke",{Parent=top,Color=Thm.Stroke,Thickness=1,Transparency=0.75})

        local tabScroll = H.mk("ScrollingFrame",{
            Parent=top,
            BackgroundTransparency=1,
            Position=UDim2.new(0,10,0,6),
            Size=UDim2.new(1,-20,1,-12),
            CanvasSize=UDim2.new(0,0,0,0),
            ScrollBarThickness=0,
            ScrollingDirection=Enum.ScrollingDirection.X,
            BorderSizePixel=0,
            ZIndex=14,
        })
        local tabList = H.mk("UIListLayout",{
            Parent=tabScroll,
            SortOrder=Enum.SortOrder.LayoutOrder,
            FillDirection=Enum.FillDirection.Horizontal,
            Padding=UDim.new(0,6),
        })

        hook(tabList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            tabScroll.CanvasSize = UDim2.new(0, tabList.AbsoluteContentSize.X + 8, 0, 0)
        end))

        local tbVel=0; local tbRun=false
        hook(tabScroll.InputChanged:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseWheel then
                tbVel = tbVel - (i.Position.Z*70)
                if not tbRun then
                    tbRun=true
                    task.spawn(function()
                        while abs(tbVel)>0.5 do
                            local maxS=mx(0,tabScroll.AbsoluteCanvasSize.X-tabScroll.AbsoluteWindowSize.X)
                            tabScroll.CanvasPosition=V2(clamp(tabScroll.CanvasPosition.X+tbVel*.1,0,maxS),0)
                            tbVel=tbVel*.84
                            task.wait()
                        end
                        tbRun=false; tbVel=0
                    end)
                end
            end
        end))

        local tabPages = H.mk("Frame",{Parent=page,BackgroundTransparency=1,Position=UDim2.new(0,0,0,38),Size=UDim2.new(1,0,1,-38),BorderSizePixel=0,ZIndex=13})
        sec.TabScroll, sec.TabPages = tabScroll, tabPages

        function sec:SelectTab(tab)
            if not tab or self.ActiveTab==tab then return end
            self.ActiveTab=tab
            for _,t in ipairs(self.Tabs) do
                local is = (t==tab)
                t.Page.Visible = is
                Tw(t.Btn,{BackgroundColor3=is and Thm.Panel2 or Thm.Panel},.12,Enum.EasingStyle.Sine)
                Tw(t.BtnTx,{TextColor3=is and Thm.AccB or Thm.Sub},.12,Enum.EasingStyle.Sine)
                Tw(t.Under,{BackgroundTransparency=is and 0 or 1},.12,Enum.EasingStyle.Sine)
            end
        end

        function sec:AddTab(tabName)
            local tab = {Name=tabName}

            local w = slen(tabName)*7+30
            sec.TabWidth += w
            tabScroll.CanvasSize = UDim2.new(0, sec.TabWidth, 0, 0)

            local tbtn = H.mk("TextButton",{Parent=tabScroll,BackgroundColor3=Thm.Panel,Size=UDim2.new(0,w,1,0),Text="",AutoButtonColor=false,BorderSizePixel=0,ZIndex=15})
            Win:_corner(tbtn)
            H.mk("UIStroke",{Parent=tbtn,Color=Thm.Stroke,Thickness=1,Transparency=0.7})

            local ttx = H.mk("TextLabel",{Parent=tbtn,BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text=tabName,TextColor3=Thm.Sub,Font=Thm.BFnt,TextSize=12,ZIndex=16})
            local under = H.mk("Frame",{Parent=tbtn,BackgroundColor3=Thm.Acc,Size=UDim2.new(1,-12,0,2),Position=UDim2.new(0,6,1,-3),BackgroundTransparency=1,BorderSizePixel=0,ZIndex=16})
            Win:_corner(under)

            local page2 = H.mk("ScrollingFrame",{Parent=tabPages,BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),
                ScrollBarThickness=3,ScrollBarImageColor3=Thm.Acc,CanvasSize=UDim2.new(0,0,0,0),
                BorderSizePixel=0,Visible=false,ZIndex=14})
            H.mk("UIPadding",{Parent=page2,PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,10),PaddingLeft=UDim.new(0,10),PaddingRight=UDim.new(0,10)})
            local layout = H.mk("UIListLayout",{Parent=page2,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,8)})

            hook(layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                page2.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y + 24)
            end))

            tab.Btn,tab.BtnTx,tab.Under,tab.Page,tab.Layout = tbtn,ttx,under,page2,layout

            local function mkRow(lbl, th)
                th = th or Thm.IH
                local row = H.mk("Frame",{Parent=page2,BackgroundColor3=Thm.Panel,Size=UDim2.new(1,0,0,th),BorderSizePixel=0,ZIndex=15})
                Win:_corner(row)
                H.mk("UIStroke",{Parent=row,Color=Thm.Stroke,Thickness=1,Transparency=0.75})

                local left = H.mk("TextLabel",{Parent=row,BackgroundTransparency=1,Position=UDim2.new(0,12,0,0),Size=UDim2.new(0.46,-12,1,0),
                    Text=lbl,TextColor3=Thm.Sub,Font=Thm.Fnt,TextSize=Thm.TSz,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=16})
                local right = H.mk("Frame",{Parent=row,BackgroundTransparency=1,Position=UDim2.new(0.46,0,0,0),Size=UDim2.new(0.54,0,1,0),ZIndex=16})
                return row,left,right
            end

            function tab:AddLabel(text)
                local _,lb,_ = mkRow(" ", 26)
                lb.Text=text or ""
                lb.TextColor3=Thm.Dim
                lb.Font=Thm.BFnt
                lb.TextSize=12
                return {SetText=function(t2) if lb then lb.Text=tostring(t2) end end}
            end

            function tab:AddSeparator()
                local sep = H.mk("Frame",{Parent=page2,BackgroundTransparency=1,Size=UDim2.new(1,0,0,10),BorderSizePixel=0,ZIndex=15})
                H.mk("Frame",{Parent=sep,BackgroundColor3=Thm.Stroke,Size=UDim2.new(1,-20,0,1),Position=UDim2.new(0,10,0.5,0),BorderSizePixel=0,ZIndex=16})
            end

            function tab:AddToggle(o)
                o=o or {}
                local st = o.Default and true or false
                local cb = o.Callback or function() end
                local _,_,right = mkRow(o.Text or "Toggle")

                local btn = H.mk("TextButton",{Parent=right,BackgroundColor3=st and Thm.AccD or Thm.Panel2,Size=UDim2.new(0,46,0,22),
                    Position=UDim2.new(0,6,0.5,-11),Text="",AutoButtonColor=false,BorderSizePixel=0,ZIndex=17})
                Win:_corner(btn)
                H.mk("UIStroke",{Parent=btn,Color=Thm.Stroke,Thickness=1,Transparency=0.65})
                local knob = H.mk("Frame",{Parent=btn,BackgroundColor3=Thm.Txt,Size=UDim2.new(0,18,0,18),
                    Position=st and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9),BorderSizePixel=0,ZIndex=18})
                Win:_corner(knob)

                local stat = H.mk("TextLabel",{Parent=right,BackgroundTransparency=1,Position=UDim2.new(0,60,0,0),Size=UDim2.new(0,80,1,0),
                    Text=st and "ON" or "OFF",TextColor3=st and Thm.Ok or Thm.Sub,Font=Thm.BFnt,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=17})

                local function set(v, anim)
                    st = v and true or false
                    local dur = anim and 0.16 or 0
                    Tw(btn,{BackgroundColor3=st and Thm.AccD or Thm.Panel2},dur,Enum.EasingStyle.Sine)
                    Tw(knob,{Position=st and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9)},dur,Enum.EasingStyle.Sine)
                    stat.Text = st and "ON" or "OFF"
                    Tw(stat,{TextColor3=st and Thm.Ok or Thm.Sub},dur,Enum.EasingStyle.Sine)
                    pcall(cb,st)
                end
                hook(btn.MouseButton1Click:Connect(function() set(not st,true) end))

                return {Set=function(v) set(v,true) end, Get=function() return st end}
            end

            function tab:AddButton(o)
                o=o or {}
                local cb=o.Callback or function() end
                local _,_,right = mkRow(o.Text or "Button")
                local b = H.mk("TextButton",{Parent=right,BackgroundColor3=Thm.AccD,Size=UDim2.new(0,96,0,24),
                    Position=UDim2.new(0,6,0.5,-12),Text=o.BtnText or "Run",TextColor3=Thm.Txt,Font=Thm.BFnt,TextSize=12,
                    AutoButtonColor=false,BorderSizePixel=0,ZIndex=17})
                Win:_corner(b)
                H.mk("UIStroke",{Parent=b,Color=Thm.Stroke2,Thickness=1,Transparency=0.4})
                hook(b.MouseEnter:Connect(function() Tw(b,{BackgroundColor3=Thm.Acc},.08,Enum.EasingStyle.Sine) end))
                hook(b.MouseLeave:Connect(function() Tw(b,{BackgroundColor3=Thm.AccD},.12,Enum.EasingStyle.Sine) end))
                hook(b.MouseButton1Click:Connect(function()
                    Tw(b,{BackgroundColor3=Thm.Txt},.04,Enum.EasingStyle.Sine)
                    task.delay(.06,function() Tw(b,{BackgroundColor3=Thm.AccD},.12,Enum.EasingStyle.Sine) end)
                    pcall(cb)
                end))
            end

            function tab:AddTextInput(o)
                o=o or {}
                local cb=o.Callback or function() end
                local _,_,right = mkRow(o.Text or "Input")
                local box = H.mk("TextBox",{Parent=right,BackgroundColor3=Thm.Panel2,Size=UDim2.new(1,-12,0,24),Position=UDim2.new(0,6,0.5,-12),
                    Text=o.Default or "",PlaceholderText=o.Placeholder or "...",TextColor3=Thm.Txt,PlaceholderColor3=Thm.Dim,Font=Thm.BFnt,TextSize=12,
                    ClearTextOnFocus=false,BorderSizePixel=0,ZIndex=17,TextXAlignment=Enum.TextXAlignment.Left})
                Win:_corner(box)
                H.mk("UIStroke",{Parent=box,Color=Thm.Stroke,Thickness=1,Transparency=0.7})
                hook(box.FocusLost:Connect(function() pcall(cb, box.Text) end))
                return {Get=function() return box.Text end, Set=function(v) box.Text=tostring(v) end}
            end

            function tab:AddDropdown(o)
                o = o or {}
                local cb      = o.Callback or function() end
                local items   = o.Items or {}
                local cur     = o.Default or (items[1] or "None")
                local searchable = (o.Searchable ~= false)

                local _,_,right = mkRow(o.Text or "Dropdown")

                local sel = H.mk("TextButton",{
                    Parent=right,
                    BackgroundColor3=Thm.Panel2,
                    Size=UDim2.new(1,-12,0,24),
