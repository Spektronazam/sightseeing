                    TextColor3=Thm.Txt,
                    Font=Thm.BFnt,
                    TextSize=12,
                    AutoButtonColor=false,
                    BorderSizePixel=0,
                    ZIndex=17,
                    TextXAlignment=Enum.TextXAlignment.Left,
                })
                Win:_corner(sel)
                H.mk("UIStroke",{
                    Parent=sel,
                    Color=Thm.Stroke,
                    Thickness=1,
                    Transparency=0.7,
                })
                H.mk("TextLabel",{
                    Parent=sel,
                    BackgroundTransparency=1,
                    Size=UDim2.new(0,20,1,0),
                    Position=UDim2.new(1,-20,0,0),
                    Text="▾",
                    TextColor3=Thm.AccB,
                    Font=Thm.BFnt,
                    TextSize=14,
                    ZIndex=18,
                })

                local function set(name, doCb)
                    name = name or "None"
                    cur = name
                    sel.Text = "  "..cur
                    if doCb then
                        pcall(cb, cur)
                    end
                end

                local function openMenu()
                    local ap = sel.AbsolutePosition
                    local as = sel.AbsoluteSize
                    local menuW = mx(220, mn(420, as.X + 40))
                    local menuH = 260

                    Win:OpenMenuAt(V2(ap.X, ap.Y + as.Y + 6), V2(menuW, menuH), function(menu)
                        local list = H.mk("ScrollingFrame",{
                            Parent=menu,
                            BackgroundTransparency=1,
                            Position=UDim2.new(0,6,0,8),
                            Size=UDim2.new(1,-12,1,-14),
                            CanvasSize=UDim2.new(0,0,0,0),
                            ScrollBarThickness=3,
                            ScrollBarImageColor3=Thm.Acc,
                            BorderSizePixel=0,
                            ZIndex=25002,
                        })
                        local ll = H.mk("UIListLayout",{
                            Parent=list,
                            SortOrder=Enum.SortOrder.LayoutOrder,
                            Padding=UDim.new(0,4),
                        })
                        hook(ll:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                            list.CanvasSize = UDim2.new(0,0,0,ll.AbsoluteContentSize.Y + 8)
                        end))

                        local function addItem(display, color)
                            local isCur = (display == cur)
                            local b = H.mk("TextButton",{
                                Parent=list,
                                BackgroundColor3=isCur and Thm.Panel2 or Thm.Base,
                                Size=UDim2.new(1,0,0,26),
                                Text="  "..display,
                                TextColor3=isCur and Thm.AccB or (color or Thm.Txt),
                                Font=Thm.BFnt,
                                TextSize=12,
                                AutoButtonColor=false,
                                BorderSizePixel=0,
                                ZIndex=25003,
                                TextXAlignment=Enum.TextXAlignment.Left,
                            })
                            Win:_corner(b)
                            H.mk("UIStroke",{
                                Parent=b,
                                Color=Thm.Stroke,
                                Thickness=1,
                                Transparency=0.85,
                            })
                            hook(b.MouseButton1Click:Connect(function()
                                set(display, true)
                                Win:CloseMenu()
                            end))
                        end

                        -- "None" first
                        addItem("None", Thm.Sub)

                        -- Live list of players (re-evaluated on each open)
                        local listPlayers = {}
                        for _,p in ipairs(svc.plrs:GetPlayers()) do
                            if p ~= svc.lp then
                                if (not Cfg.misc.whitelist) or wlCheck(p.Name) then
                                    listPlayers[#listPlayers+1] = p
                                end
                            end
                        end
                        tsort(listPlayers, function(a,b) return a.Name < b.Name end)

                        for _,p in ipairs(listPlayers) do
                            local alive = H.isAlive(p)
                            local col = alive and Thm.Txt or Thm.Dim
                            addItem(p.Name, col)
                        end
                    end)
                end

                hook(sel.MouseButton1Click:Connect(function()
                    if Win.MenuActive then
                        Win:CloseMenu()
                    else
                        openMenu()
                    end
                end))

                task.defer(function() pcall(cb, cur) end)

                -- also provide a backup manual entry under the dropdown
                tab:AddTextInput({
                    Text        = "Target (manual)",
                    Placeholder = "Exact username...",
                    Default     = (cur ~= "None" and cur or ""),
                    Callback    = function(v)
                        v = (v or ""):match("^%s*(.-)%s*$")
                        if v == "" then
                            set("None", true)
                        else
                            set(v, true)
                        end
                    end
                })

                return {
                    Set = function(v) set(v, true) end,
                    Get = function() return cur end,
                }
            end

            hook(tbtn.MouseButton1Click:Connect(function() sec:SelectTab(tab) end))
            sec.Tabs[#sec.Tabs+1]=tab
            if #sec.Tabs==1 then task.defer(function() sec:SelectTab(tab) end) end
            return tab
        end

        hook(btn.MouseButton1Click:Connect(function() selectSection(sec) end))
        Win.Sections[#Win.Sections+1]=sec
        if #Win.Sections==1 then task.defer(function() selectSection(sec) end) end
        return sec
    end

    return Win
end

