local Draw = {
	alive = setmetatable({},{__mode="k"}),
	count = 0,
	LIMIT = 3000,
	defFont = (Cap.drawFonts and Drawing.Fonts.Plex) or 0,
}

local function mkDraw(kind,props)
	if not Cap.drawing or Draw.count >= Draw.LIMIT then return nil end
	local ok,d = pcall(Drawing.new,kind)
	if not ok or not d then return nil end
	Draw.count += 1
	Draw.alive[d] = true
	if props then
		for k,v in pairs(props) do pcall(function() d[k]=v end) end
	end
	pcall(function() d.Visible = props and props.Visible or false end)
	return d
end
local function dVis(d,v)  if d and Draw.alive[d] then pcall(function() d.Visible=v end) end end
local function dSet(d,k,v) if d and Draw.alive[d] then pcall(function() d[k]=v end) end end
local function dNuke(d)
	if not d then return end
	if Draw.alive[d] then Draw.count=mx(0,Draw.count-1) Draw.alive[d]=nil end
	pcall(function() d.Visible=false end)
	pcall(function() d:Remove() end)
end
local function mkText(p)
	p=p or {}
	return mkDraw("Text",{
		Text=p.Text or "", Size=p.Size or 14, Font=p.Font or Draw.defFont,
		Position=p.Position or ZV2, Center=p.Center or false,
		Outline=p.Outline~=nil and p.Outline or true,
		Color=p.Color or WHITE, Transparency=p.Alpha or 1,
		Visible=false, ZIndex=p.Z or 50,
	})
end
local function mkRect(p)
	p=p or {}
	return mkDraw("Square",{
		Size=p.Size or V2(10,10), Position=p.Position or ZV2,
		Color=p.Color or WHITE, Filled=p.Filled or false,
		Thickness=p.Thick or 1, Transparency=p.Alpha or 1,
		Visible=false, ZIndex=p.Z or 50,
	})
end
local function mkLine(p)
	p=p or {}
	return mkDraw("Line",{
		From=p.From or ZV2, To=p.To or ZV2,
		Color=p.Color or WHITE, Thickness=p.Thick or 1,
		Transparency=p.Alpha or 1, Visible=false, ZIndex=p.Z or 50,
	})
end
local function mkCirc(p)
	p=p or {}
	return mkDraw("Circle",{
		Position=p.Position or ZV2, Radius=p.R or 10,
		Color=p.Color or WHITE, Filled=p.Filled or false,
		Thickness=p.Thick or 1, Transparency=p.Alpha or 1,
		NumSides=p.Sides or 64, Visible=false, ZIndex=p.Z or 50,
