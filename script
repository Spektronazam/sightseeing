-- ═════════════════════════════════════════════════════════════
--  VELOCITY BUFFER
-- ═════════════════════════════════════════════════════════════
local VB = {data={}, MAX=10, ALPHA=0.25}
local function smoothedVel(root)
	if not root then return ZV3 end
	local ok,vel = pcall(function() return root.AssemblyLinearVelocity end)
	if not ok then return ZV3 end
	vel = H.safeV3(vel)
	local chr = H.prop(root,"Parent"); if not chr then return vel end
	local b = VB.data[chr]
	if not b then b={s=tcreate(VB.MAX),i=0,c=0,est=vel} VB.data[chr]=b end
	b.est = H.lerpV3(b.est,vel,VB.ALPHA)
	b.i = (b.i%VB.MAX)+1; b.s[b.i]=b.est; b.c=mn(b.c+1,VB.MAX)
	local sum,w = ZV3,0
	for i=1,b.c do
		local idx=((b.i-i)%VB.MAX)+1; local sv=b.s[idx]
		if sv then local wt=exp(-(i-1)*0.25); sum=sum+sv*wt; w+=wt end
	end
	return w>0 and H.safeV3(sum*(1/w)) or b.est
end

