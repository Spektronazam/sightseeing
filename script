--  TARGET CYCLING
-- ═════════════════════════════════════════════════════════════
local function cycleTarget(dir2)
	local plrs2={}
	for _,p in ipairs(svc.plrs:GetPlayers()) do
		if p~=svc.lp and H.isAlive(p) and wlCheck(p.Name) then plrs2[#plrs2+1]=p end
	end
	if #plrs2==0 then pushNf("No targets",1.5,"warning"); return end
	tsort(plrs2,function(a,b) return a.Name<b.Name end)
	local ci=0
	for i,p in ipairs(plrs2) do if p.Name==Cfg.orbit.targetName then ci=i; break end end
	ci=ci+dir2; if ci<1 then ci=#plrs2 end; if ci>#plrs2 then ci=1 end
	Cfg.orbit.targetName=plrs2[ci].Name; Orb.state="idle"
	pushNf("Target → "..plrs2[ci].Name,2,"orbit")
	if UI.tgtDD and UI.tgtDD.Set then UI.tgtDD.Set(plrs2[ci].Name) end
end

