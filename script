-- ═════════════════════════════════════════════════════════════
--  CAMERA
-- ═════════════════════════════════════════════════════════════
local Cam = {
	active=false, cf=nil, lookTarget=nil, lockPos=nil,
	engaged=false, phase="idle", panBlend=0, cooldown=0,
	lastValidCF=nil, tgtAlive=false, tgtPos=nil, lastTgtPos=nil,
}
local CAM_KEY = "DESPAIRv81_CAM"
pcall(function() svc.rs:UnbindFromRenderStep(CAM_KEY) end)
svc.rs:BindToRenderStep(CAM_KEY,Enum.RenderPriority.Camera.Value+1,function()
	if Cam.active and Cam.cf then pcall(function() svc.cam.CFrame=Cam.cf end) end
end)

local function engageCam()  if not Cam.engaged then Cam.engaged=true end end
local function disengageCam()
	if not Cam.engaged and not Cam.active then return end
	Cam.active=false; Cam.cf=nil; Cam.lockPos=nil; Cam.lookTarget=nil
	Cam.phase="idle"; Cam.panBlend=0; Cam.lastValidCF=nil
	if Cam.engaged then
		Cam.engaged=false
		pcall(function()
			svc.cam.CameraType=Enum.CameraType.Custom
			local hum=H.getHum(H.myChr())
			if hum then svc.cam.CameraSubject=hum end
		end)
	end
end

local function tickCameraSystem(dt)
	if Cfg.orbit.camMode=="Free" then disengageCam(); return end
	if Cam.cooldown>0 then Cam.cooldown=mx(0,Cam.cooldown-dt); disengageCam(); return end
	local hum=H.getHum(H.myChr()); local inCut = (not hum) or ((H.prop(hum,"Health") or 0) <= 0)
	if inCut or not Cfg.orbit.on or Orb.state=="idle" then disengageCam(); return end
	safe(function()
		local myRoot=H.myRoot(); if not myRoot then disengageCam(); return end
		local myPos=H.safeV3(myRoot.Position); if myPos==ZV3 then return end
		local tAlive,tPos=Cam.tgtAlive,Cam.tgtPos

		if Cam.phase=="idle" or Cam.phase=="track_target" then
			if tAlive and tPos then Cam.phase="track_target"
			elseif not tAlive then
				if Cam.phase=="track_target" then Cam.lastTgtPos=tPos or Cam.lastTgtPos end
				Cam.phase="return_to_player"; Cam.panBlend=0
			end
		elseif Cam.phase=="return_to_player" then
			if tAlive and tPos and (myPos-tPos).Magnitude<=Cfg.orbit.camReturnDist then
				Cam.phase="pan_to_target"; Cam.panBlend=0
			end
		elseif Cam.phase=="pan_to_target" then
			Cam.panBlend=mn(1,Cam.panBlend+dt*clamp(Cfg.orbit.camPanSpeed,0.3,5))
			if Cam.panBlend>=0.98 then Cam.phase="track_target"; Cam.panBlend=1 end
			if not tAlive then Cam.phase="return_to_player"; Cam.panBlend=0 end
		end

		local function getBehind()
			local bd=-myRoot.CFrame.LookVector; local fb=V3(bd.X,0,bd.Z)
			if fb.Magnitude<0.1 then fb=V3(0,0,1) end; return fb.Unit
		end

		local lookGoal,camGoal
		if Cam.phase=="track_target" and tAlive and tPos then
			lookGoal=tPos
			if Cfg.orbit.camMode=="Lock" then
				camGoal=tPos+V3(0,Cfg.orbit.camLockHeight,Cfg.orbit.camLockDist)
			else
				local dir=H.safeV3(myPos-tPos); local flat=V3(dir.X,0,dir.Z)
				if flat.Magnitude<0.1 then flat=getBehind() end
				camGoal=myPos+flat.Unit*Cfg.orbit.camLockDist+V3(0,Cfg.orbit.camLockHeight,0)
			end
		elseif Cam.phase=="return_to_player" then
			lookGoal=myPos+V3(0,2,0); camGoal=myPos+getBehind()*Cfg.orbit.camLockDist+V3(0,Cfg.orbit.camLockHeight,0)
		elseif Cam.phase=="pan_to_target" and tPos then
			local eb=Cam.panBlend*Cam.panBlend*(3-2*Cam.panBlend)
			lookGoal=H.lerpV3(myPos+V3(0,2,0),tPos,eb)
			local pcg=myPos+getBehind()*Cfg.orbit.camLockDist+V3(0,Cfg.orbit.camLockHeight,0)
			local tcg
			if Cfg.orbit.camMode=="Lock" then
				tcg=tPos+V3(0,Cfg.orbit.camLockHeight,Cfg.orbit.camLockDist)
			else
				local dir=H.safeV3(myPos-tPos); local flat=V3(dir.X,0,dir.Z)
				if flat.Magnitude<0.1 then flat=getBehind() end
				tcg=myPos+flat.Unit*Cfg.orbit.camLockDist+V3(0,Cfg.orbit.camLockHeight,0)
			end
			camGoal=H.lerpV3(pcg,tcg,eb)
		else
			lookGoal=myPos+V3(0,2,0); camGoal=myPos+getBehind()*Cfg.orbit.camLockDist+V3(0,Cfg.orbit.camLockHeight,0)
		end

		camGoal=H.safeV3(camGoal); lookGoal=H.safeV3(lookGoal)
		local sf=clamp(Cfg.orbit.camChaseSmooth*0.04,0.02,1)
		Cam.lookTarget=Cam.lookTarget and H.dampV3(Cam.lookTarget,lookGoal,sf*1.8,dt) or lookGoal
		Cam.lockPos   =Cam.lockPos    and H.dampV3(Cam.lockPos,   camGoal, sf,    dt) or camGoal
		Cam.lockPos=H.safeV3(Cam.lockPos); Cam.lookTarget=H.safeV3(Cam.lookTarget)
		if (Cam.lookTarget-Cam.lockPos).Magnitude<0.1 then Cam.lookTarget=Cam.lockPos+V3(0,0,-1) end
		local newCF=CF(Cam.lockPos,Cam.lookTarget); local p2=newCF.Position
		if p2.X==p2.X and p2.Y==p2.Y and p2.Z==p2.Z then
			Cam.cf=newCF; Cam.lastValidCF=newCF; engageCam(); Cam.active=true
		elseif Cam.lastValidCF then Cam.cf=Cam.lastValidCF end
	end)
end

