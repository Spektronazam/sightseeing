--  KEYBIND MAP
-- ═════════════════════════════════════════════════════════════
local Kmap = {
	Q=Enum.KeyCode.Q, E=Enum.KeyCode.E, X=Enum.KeyCode.X, C=Enum.KeyCode.C, V=Enum.KeyCode.V,
	F=Enum.KeyCode.F, Z=Enum.KeyCode.Z, T=Enum.KeyCode.T, R=Enum.KeyCode.R, G=Enum.KeyCode.G,
	H=Enum.KeyCode.H, J=Enum.KeyCode.J, K=Enum.KeyCode.K, L=Enum.KeyCode.L, N=Enum.KeyCode.N,
	M=Enum.KeyCode.M, P=Enum.KeyCode.P, B=Enum.KeyCode.B, Y=Enum.KeyCode.Y, U=Enum.KeyCode.U,
	I=Enum.KeyCode.I, O=Enum.KeyCode.O,
	CapsLock=Enum.KeyCode.CapsLock, LeftAlt=Enum.KeyCode.LeftAlt, LeftShift=Enum.KeyCode.LeftShift,
	Tab=Enum.KeyCode.Tab, Insert=Enum.KeyCode.Insert, Delete=Enum.KeyCode.Delete,
	F1=Enum.KeyCode.F1, F2=Enum.KeyCode.F2, F3=Enum.KeyCode.F3, F4=Enum.KeyCode.F4, F5=Enum.KeyCode.F5, F6=Enum.KeyCode.F6,
	One=Enum.KeyCode.One, Two=Enum.KeyCode.Two, Three=Enum.KeyCode.Three, Four=Enum.KeyCode.Four, Five=Enum.KeyCode.Five,
}
local function keyMatch(name,inp)
	if not name or name=="None" or not inp then return false end
	local kc=Kmap[name]; return kc and inp.KeyCode==kc
end

hook(svc.uis.InputBegan:Connect(function(inp,gpe)
	if gpe then return end
	if keyMatch(Cfg.orbit.toggleKey,inp) then
		Cfg.orbit.on=not Cfg.orbit.on
		if not Cfg.orbit.on then transitionToIdle(); disengageCam() end
		if UI.orbitToggle and UI.orbitToggle.Set then UI.orbitToggle.Set(Cfg.orbit.on) end
		pushNf(Cfg.orbit.on and "Orbit ON" or "Orbit OFF",2,Cfg.orbit.on and "orbit" or "warning")
	end
	if keyMatch(Cfg.orbit.reverseKey,inp) then
		Orb.direction=Orb.direction*-1
		pushNf("Dir: "..(Orb.direction>0 and "CW" or "CCW"),1.5,"info")
	end
	if keyMatch(Cfg.orbit.freezeKey,inp) then
		Orb.frozen=not Orb.frozen
		pushNf(Orb.frozen and "Frozen" or "Unfrozen",1.5,Orb.frozen and "info" or "success")
	end
	if keyMatch(Cfg.orbit.cycleNextKey,inp) then cycleTarget(1)  end
	if keyMatch(Cfg.orbit.cyclePrevKey,inp) then cycleTarget(-1) end
	if keyMatch(Cfg.orbit.ghostKey,inp) then
		Cfg.misc.ghost=not Cfg.misc.ghost
		setGhost(Cfg.misc.ghost)
		pushNf(Cfg.misc.ghost and "Ghost ON" or "Ghost OFF",1.5,Cfg.misc.ghost and "info" or "warning")
	end
end))

