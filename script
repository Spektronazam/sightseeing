local AP -- forward decl (we set after definition)

local function saveCfg(name)
	local file = name and (PROFILE_DIR..name..".json") or CFG_FILE

	-- sync runtime → config for autopress
	if AP then
		Cfg.misc.autoPress  = AP.on
		Cfg.misc.apKey      = AP.key
		Cfg.misc.apInterval = AP.interval
		Cfg.misc.apDuration = AP.duration
	end

	local t={}
	for cat,tbl in pairs(Cfg) do
		t[cat]={}
		for k,v in pairs(tbl) do t[cat][k]=v end
	end
