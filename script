--  ERROR BOUNDARY
-- ═════════════════════════════════════════════════════════════
local Err = {count=0, log={}, MAX=80, LIMIT=1000}
local function safe(fn,...)
	local ok,e = pcall(fn,...)
	if not ok then
		Err.count += 1
		if #Err.log < Err.MAX then
			Err.log[#Err.log+1] = {t=tk(), e=ssub(tostring(e),1,220)}
		end
		if Err.count > Err.LIMIT then
			warn("[DESPAIR v8.3] Error threshold exceeded — unloading.")
			if _G.DESPAIRv8Cleanup then task.defer(_G.DESPAIRv8Cleanup) end
		end
	end
	return ok,e
end

