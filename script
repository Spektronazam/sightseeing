                    sel.Text = "  "..cur
                    if doCb then
                        pcall(cb, cur)
                    end
                end

                local function openMenu()
                    local ap = sel.AbsolutePosition
                    local as = sel.AbsoluteSize
                    local menuW = mx(240, mn(420, as.X + 40))
                    local menuH = 300

                    Win:OpenMenuAt(V2(ap.X, ap.Y + as.Y + 6), V2(menuW, menuH), function(menu)
                        local search
                        if searchable then
                            search = H.mk("TextBox",{
                                Parent=menu,
                                BackgroundColor3=Thm.Panel,
                                Size=UDim2.new(1,-12,0,26),
                                Position=UDim2.new(0,6,0,6),
                                Text="",
                                PlaceholderText="Search...",
                                TextColor3=Thm.Txt,
                                PlaceholderColor3=Thm.Dim,
                                Font=Thm.BFnt,
                                TextSize=12,
                                ClearTextOnFocus=false,
                                BorderSizePixel=0,
                                ZIndex=25002,
                                TextXAlignment=Enum.TextXAlignment.Left,
                            })
                            Win:_corner(search)
                            H.mk("UIStroke",{
                                Parent=search,
                                Color=Thm.Stroke,
                                Thickness=1,
                                Transparency=0.75,
                            })
                        end

                        local list = H.mk("ScrollingFrame",{
                            Parent=menu,
                            BackgroundTransparency=1,
                            Position=UDim2.new(0,6,0,searchable and 40 or 8),
                            Size=UDim2.new(1,-12,1,-(searchable and 46 or 14)),
                            CanvasSize=UDim2.new(0,0,0,0),
                            ScrollBarThickness=3,
                            ScrollBarImageColor3=Thm.Acc,
                            BorderSizePixel=0,
                            ZIndex=25002,
                        })
                        local ll = H.mk("UIListLayout",{
                            Parent=list,
                            SortOrder=Enum.SortOrder.LayoutOrder,
                            Padding=UDim.new(0,4),
                        })
                        hook(ll:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                            list.CanvasSize = UDim2.new(0,0,0,ll.AbsoluteContentSize.Y + 8)
                        end))

                        local function build(filter)
                            filter = slow(filter or "")
                            for _,c in ipairs(list:GetChildren()) do
                                if c:IsA("TextButton") then c:Destroy() end
                            end
                            for _,it in ipairs(items) do
                                local v = tostring(it)
                                if filter=="" or string.find(slow(v), filter, 1, true) then
                                    local b = H.mk("TextButton",{
                                        Parent=list,
                                        BackgroundColor3=(v==cur) and Thm.Panel or Thm.Base,
                                        Size=UDim2.new(1,0,0,26),
                                        Text="  "..v,
                                        TextColor3=(v==cur) and Thm.AccB or Thm.Txt,
                                        Font=Thm.BFnt,
                                        TextSize=12,
                                        AutoButtonColor=false,
                                        BorderSizePixel=0,
                                        ZIndex=25003,
                                        TextXAlignment=Enum.TextXAlignment.Left,
                                    })
                                    Win:_corner(b)
                                    H.mk("UIStroke",{
                                        Parent=b,
                                        Color=Thm.Stroke,
                                        Thickness=1,
                                        Transparency=0.85,
                                    })
                                    hook(b.MouseButton1Click:Connect(function()
                                        set(v, true)
                                        Win:CloseMenu()
                                    end))
                                end
                            end
                        end

                        build("")
                        if searchable and search then
                            hook(search:GetPropertyChangedSignal("Text"):Connect(function()
                                build(search.Text)
                            end))
                            task.defer(function() pcall(function() search:CaptureFocus() end) end)
                        end
                    end)
                end

                hook(sel.MouseButton1Click:Connect(function()
                    if Win.MenuActive then
                        Win:CloseMenu()
                    else
                        openMenu()
                    end
                end))

                task.defer(function() pcall(cb, cur) end)

                local api = {}

                function api.Set(v)
                    set(v, true)
                end

                function api.Get()
                    return cur
                end

                function api.SetItems(newItems)
                    items = newItems or {}
                    local found=false
                    for _,it in ipairs(items) do
                        if tostring(it) == cur then found=true break end
                    end
                    if not found then
                        local nv = items[1] and tostring(items[1]) or "None"
                        cur = nv
                        sel.Text = "  "..cur
                    end
                end

                return api
            end

            -- Player dropdown: builds live list each time you open it
            function tab:AddPlayerDropdown(o)
                o=o or {}
                local cb  = o.Callback or function() end
                local cur = o.Default or "None"

                local _,_,right = mkRow(o.Text or "Target player")

                local sel = H.mk("TextButton",{
                    Parent=right,
                    BackgroundColor3=Thm.Panel2,
                    Size=UDim2.new(1,-12,0,24),
                    Position=UDim2.new(0,6,0.5,-12),
