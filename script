-- ═════════════════════════════════════════════════════════════
local function getTargetWorldPos(root)
	local ok,pos = pcall(function() return root.Position end); if not ok then return ZV3 end
	pos = H.safeV3(pos) + V3(Cfg.orbit.offX,Cfg.orbit.offY,Cfg.orbit.offZ)
	if Cfg.orbit.prediction then
		local vel = smoothedVel(root)
		if vel.Magnitude > 0.5 then
			local pingComp = Cfg.orbit.predPing and getPing()/1000 or 0
			pos = H.safeV3(pos + vel*(Cfg.orbit.predStr + pingComp))
		end
	end
	return pos
end

