local function mkNfSlot()
	local s = {}
	s.shadow = mkRect({Filled=true, Color=C3(0,0,0), Z=11000, Alpha=0.7})
	s.bg     = mkRect({Filled=true, Color=C3(0,0,0), Z=11001, Alpha=0.86})
	s.bord   = mkRect({Thick=1,      Color=C3(80,30,140), Z=11002, Alpha=0.35})
	s.acc    = mkRect({Filled=true,  Color=C3(190,120,255), Z=11002, Alpha=0.85})
	s.tx     = mkText({Size=14, Z=11003, Alpha=0.95})
	s.icon   = mkText({Size=14, Center=true, Z=11003, Alpha=0.95})
	s.prog   = mkRect({Filled=true,  Z=11000, Alpha=0.55})
	return s
end

local function pushNf(msg,dur,nt)
	dur = dur or 3; nt = nt or "info"
	local style = NfStyle[nt] or NfStyle.info
	local slot  = tremove(Nf.pool) or mkNfSlot()
	if not slot then return end
	slot.msg   = ssub(tostring(msg),1,160)
	slot.born  = tk(); slot.life = dur
	slot.alpha = 0
	slot.color = style.color
	slot.icon  = style.icon
	slot.offY  = -18
	Nf.active[#Nf.active+1] = slot
end

local function tickNfs(dt)
	local now = tk()
	local scale = clamp(Cfg.ui.toastScale or 1, 0.7, 1.5)
	local padX, padY = 14*scale, 10*scale
	local gap = 8*scale

	local centerX = F.scrX
	local topY = 22

	local dead=nil
	for i,n in ipairs(Nf.active) do
		local age = now - n.born
		local a = mn(clamp(age/.14,0,1), clamp((n.life-age)/.22,0,1))
		n.alpha = a
		n.offY  = H.damp(n.offY,0,0.35,dt)
		if age > n.life then
			dead = dead or {}; dead[#dead+1]=i
			dVis(n.shadow,false); dVis(n.bg,false); dVis(n.bord,false)
			dVis(n.acc,false); dVis(n.tx,false); dVis(n.icon,false); dVis(n.prog,false)
		else
			dSet(n.tx,"Text",n.msg)
			dSet(n.tx,"Color",Thm.Txt)

			local tb = (Draw.alive[n.tx] and H.prop(n.tx,"TextBounds")) or V2(slen(n.msg)*8,16)
			local bw = tb.X + padX*2 + 34*scale
			local bh = tb.Y + padY*2

			local px = centerX - bw/2
			local py = topY + (i-1)*(bh+gap) + n.offY

			dSet(n.shadow,"Size",V2(bw, bh))
			dSet(n.shadow,"Position",V2(px+2, py+3))
			dSet(n.shadow,"Transparency",0.65*a)
			dVis(n.shadow,true)

			dSet(n.bg,"Size",V2(bw, bh))
			dSet(n.bg,"Position",V2(px, py))
			dSet(n.bg,"Transparency",0.88*a)
			dVis(n.bg,true)

			dSet(n.bord,"Size",V2(bw, bh))
			dSet(n.bord,"Position",V2(px, py))
			dSet(n.bord,"Color",n.color)
			dSet(n.bord,"Transparency",0.25*a)
			dVis(n.bord,true)

			dSet(n.acc,"Size",V2(4*scale, bh-6))
			dSet(n.acc,"Position",V2(px+2, py+3))
			dSet(n.acc,"Color",n.color)
			dSet(n.acc,"Transparency",0.85*a)
			dVis(n.acc,true)

			dSet(n.icon,"Text",n.icon)
			dSet(n.icon,"Color",n.color)
			dSet(n.icon,"Position",V2(px+18*scale, py+bh/2-7*scale))
			dSet(n.icon,"Transparency",0.95*a)
			dVis(n.icon,true)

			dSet(n.tx,"Position",V2(px+34*scale, py+padY-1))
			dSet(n.tx,"Transparency",0.98*a)
			dVis(n.tx,true)

			local pct = clamp(1-(age/n.life),0,1)
			dSet(n.prog,"Size",V2(bw*pct, 2))
			dSet(n.prog,"Position",V2(px, py+bh-2))
			dSet(n.prog,"Color",n.color)
			dSet(n.prog,"Transparency",0.55*a)
			dVis(n.prog,true)
		end
	end
	if dead then
		for j=#dead,1,-1 do
			local n = tremove(Nf.active,dead[j])
			dVis(n.shadow,false); dVis(n.bg,false); dVis(n.bord,false)
			dVis(n.acc,false); dVis(n.tx,false); dVis(n.icon,false); dVis(n.prog,false)
			Nf.pool[#Nf.pool+1] = n
		end
	end
end

