--  SMART MATERIAL
-- ═════════════════════════════════════════════════════════════
local Mat = {originals={}, active={}, faded={}}
local matOLP = OverlapParams.new()
matOLP.FilterType=Enum.RaycastFilterType.Exclude

local function tickSmartMat()
	if not Cfg.misc.matOn then
		for p,orig in pairs(Mat.originals) do if p and p.Parent then pcall(function() p.Material=orig end) end end
		for p,orig in pairs(Mat.faded)     do if p and p.Parent then pcall(function() p.Transparency=orig end) end end
		Mat.originals={}; Mat.active={}; Mat.faded={}; dVis(D.matCirc,false); return
	end
	local chr=H.myChr(); if not H.validChr(chr) then dVis(D.matCirc,false); return end
	local root=H.getRoot(chr); if not root then dVis(D.matCirc,false); return end
	local center=root.Position
	local radius=Cfg.misc.matRadius
	local ok3,gme=pcall(function() return Enum.Material[Cfg.misc.matType] end)
	local goalMat=ok3 and gme or Enum.Material.Glass
	matOLP.FilterDescendantsInstances={chr}
	local ok4,parts=pcall(svc.ws.GetPartBoundsInRadius,svc.ws,center,radius,matOLP)
	if not ok4 or not parts then return end
	local inRange={}
	for _,p in ipairs(parts) do
		if p:IsA("BasePart") and not p:IsDescendantOf(chr) then
			inRange[p]=true
			if not Mat.originals[p] then Mat.originals[p]=p.Material end
			if p.Material~=goalMat then pcall(function() p.Material=goalMat end) end
			Mat.active[p]=true
			if Cfg.misc.matFade then
				local d=(p.Position-center).Magnitude
				local ed=radius-d
				if ed<Cfg.misc.matFadeRange and ed>0 then
					if not Mat.faded[p] then Mat.faded[p]=p.Transparency end
					pcall(function() p.Transparency=mx(Mat.faded[p] or 0,clamp(1-(ed/Cfg.misc.matFadeRange),0,0.8)) end)
				elseif Mat.faded[p] then
					pcall(function() p.Transparency=Mat.faded[p] end); Mat.faded[p]=nil
				end
			end
		end
	end
	for p in pairs(Mat.active) do
		if not inRange[p] then
			if Mat.originals[p] and p and p.Parent then pcall(function() p.Material=Mat.originals[p] end) end
			if Mat.faded[p]    and p and p.Parent then pcall(function() p.Transparency=Mat.faded[p]    end) end
			Mat.originals[p]=nil; Mat.active[p]=nil; Mat.faded[p]=nil
		end
	end
	for p in pairs(Mat.originals) do
		if not p or not p.Parent then Mat.originals[p]=nil; Mat.active[p]=nil; Mat.faded[p]=nil end
	end
	if Cfg.misc.matShowRadius and Draw.alive[D.matCirc] then
		local sp,on = H.w2v(center)
		if on and sp then
			local okE,ep = pcall(function() return svc.cam:WorldToViewportPoint(center+svc.cam.CFrame.RightVector*radius) end)
			if okE and ep then
				dSet(D.matCirc,"Position",V2(sp.X,sp.Y))
				dSet(D.matCirc,"Radius",mx((V2(sp.X,sp.Y)-V2(ep.X,ep.Y)).Magnitude,5))
				dSet(D.matCirc,"Color",Thm.Acc); dSet(D.matCirc,"Transparency",0.35); dVis(D.matCirc,true)
			end
		else dVis(D.matCirc,false) end
	else dVis(D.matCirc,false) end
end

