hook(svc.lp.CharacterRemoving:Connect(function()
	disengageCam(); Cam.cooldown=3.5
	pcall(function() svc.cam.CameraType=Enum.CameraType.Custom end)
	Ghost.origTrans={}
end))
hook(svc.lp.CharacterAdded:Connect(function(chr)
	disengageCam(); if Cam.cooldown<2 then Cam.cooldown=2 end
	task.defer(function()
		local timeout=tk()+6
		while tk()<timeout do
			local r=H.getRoot(chr); local hm=H.getHum(chr)
			if r and hm and H.prop(hm,"Health") and H.prop(hm,"Health")>0 then break end
			task.wait(0.15)
		end
		pcall(function()
			local hum=H.getHum(chr)
			if hum then svc.cam.CameraType=Enum.CameraType.Custom; svc.cam.CameraSubject=hum end
		end)
		if Cfg.misc.fly then task.defer(function() setFly(true) end) end
		if Cfg.misc.ghost then task.defer(function() setGhost(true) end) end
	end)
end))

