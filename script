--  PERFORMANCE MONITOR
-- ═════════════════════════════════════════════════════════════
local Perf = {fps=60, frames=0, last=tk(), ping=50, pingT=0}
local function tickFps()
	Perf.frames += 1
	local now = tk()
	if now - Perf.last >= 0.5 then
		Perf.fps    = floor(Perf.frames / (now-Perf.last) + 0.5)
		Perf.frames = 0
		Perf.last   = now
	end
end
local function getPing()
	local now = tk()
	if now - Perf.pingT < 2 then return Perf.ping end
	Perf.pingT = now
	pcall(function()
		local st = svc.stats
		if not st then return end
		local net = H.prop(st,"Network"); if not net then return end
		local item = H.prop(net,"ServerStatsItem"); if not item then return end
		local p = item["Data Ping"]
		if p then Perf.ping = floor(clamp(p:GetValue(),1,9999)) end
	end)
	return Perf.ping
end

